{
  "manifest_version": 3,
  "name": "Dropy Pass-Funnel Validator",
  "version": "0.1.0",
  "description": "Re-checks the FUNNEL of rows in the Pass file using category-specific BSR thresholds, and writes the BSR rank into Remark. Separate from Dropy Auto-Validator.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "sidePanel",
    "alarms",
    "power"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Dropy Pass-Funnel Validator"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.in/*",
        "https://amazon.in/*",
        "https://www.amazon.com/*",
        "https://amazon.com/*"
      ],
      "js": ["content/amazon.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.in/*",
        "https://www.flipkart.com/*",
        "https://www.nykaa.com/*",
        "https://www.meesho.com/*",
        "https://www.jiomart.com/*"
      ],
      "js": ["content/marketplace.js"],
      "run_at": "document_idle"
    }
  ],
  "minimum_chrome_version": "114"
}
